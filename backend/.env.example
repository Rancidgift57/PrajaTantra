PRAJATANTRA_API_TITLE=Prajatantra Simulation API
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password
NEO4J_DATABASE=neo4j
FRONTEND_ORIGIN=http://localhost:3000
# Optional: comma-separated list if you need more than one allowed origin
# (e.g. a deployed frontend URL alongside local dev). localhost/127.0.0.1
# on any port are always allowed automatically, so you don't need to list
# those.
# FRONTEND_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Supabase/Postgres. Leave unset to run with the in-memory auth store
# (fine for local dev). Get this from Supabase: Project Settings ->
# Database -> Connection string -> "Transaction pooler" (port 6543).
# DATABASE_URL=postgresql://postgres.xxxxxxxxxxxx:[email protected]:6543/postgres

# Secret used to sign session tokens — set this to a real random value
# before deploying anywhere public. Changing it invalidates all sessions.
PRAJATANTRA_TOKEN_SECRET=prajatantra-dev-secret-change-me

# Optional: enables Redis-backed cooldowns for Tactical Cards (see
# services/cooldown_store.py). Without it, cooldowns fall back to an
# in-memory dict — fine for local dev / a single backend process.
# REDIS_URL=redis://localhost:6379/0

# HuggingFace Inference API — powers AI manifesto judging (zero-shot
# classification: credible funded plan / vague populist promise / corrupt
# or unfunded promise) in services/manifesto_ai.py. Leave unset to fall
# back to a deterministic offline keyword heuristic — the mechanic still
# works, it just won't be "real AI" until you set a token. Get a token at
# https://huggingface.co/settings/tokens (read-only access is enough).
# HUGGINGFACE_API_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Optional: override the default zero-shot model (facebook/bart-large-mnli).
# HF_MANIFESTO_MODEL=facebook/bart-large-mnli

